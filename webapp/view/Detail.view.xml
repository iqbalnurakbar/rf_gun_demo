<mvc:View xmlns:core="sap.ui.core" controllerName="rfgundemo.controller.Detail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form">
    <Page id="dataDetailPage" title="Detail Page">

        <List id="itemsList" headerText="Order Details" class="sapUiTinyMarginTop">
            <!-- Items will be bound manually from controller -->
        </List>

        <footer>
            <Toolbar design="Solid">
                <ToolbarSpacer />
                <Button text="Back (F3)" press="onNavBack" />
                <ToolbarSpacer />
                <Button text="Save (F8)" press="onSaveAll" />
                <ToolbarSpacer />
            </Toolbar>
        </footer>
    </Page>
</mvc:View>