<mvc:View xmlns:core="sap.ui.core" controllerName="rfgundemo.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form">
    <Page id="page" title="{i18n>title}">
        <content>
            <VBox class="sapUiSmallMargin">
                <Label text="Purchase Order" labelFor="plantInput" textAlign="Center"/>
                <Input id="plantInput" placeholder="Enter PO number" required="true" showValueHelp="true" valueHelpRequest=".onPlantValueHelp" change=".onInputChange" maxLength="10"/>
            </VBox>
        </content>
        <footer>
            <Toolbar design="Solid">
                <ToolbarSpacer />
                <Text text="Back (F3)" />
                <ToolbarSpacer />
                <Text text="Enter (F4)" />
                <ToolbarSpacer />
            </Toolbar>
        </footer>
    </Page>
</mvc:View>
