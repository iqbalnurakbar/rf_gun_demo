<mvc:View xmlns:core="sap.ui.core" controllerName="rfgundemo.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form">
    <Page id="page" title="{i18n>title}">
        <content>
            <VBox class="sapUiSmallMargin">
                <Label text="Plant" labelFor="plantInput" />
                <HBox justifyContent="SpaceBetween">
                    <Input id="plantInput" placeholder="Enter Plant" required="true" showValueHelp="true" valueHelpRequest=".onPlantValueHelp" change=".onInputChange" maxLength="4" width="95%">
                        <layoutData>
                            <FlexItemData growFactor="1" />
                        </layoutData>
                    </Input>
                    <core:Icon id="checkPlant" color="green" src="sap-icon://sys-enter-2" size="26px" visible="false"/>
                </HBox>
                <Label text="Warehouse Type" labelFor="warehouseTypeInput" />
                <HBox>
                    <Input id="warehouseTypeInput" placeholder="Enter Warehouse Type" required="true" showValueHelp="true" valueHelpRequest=".onWarehouseTypeValueHelp" change=".onInputChange" maxLength="2" width="95%">
                        <layoutData>
                            <FlexItemData growFactor="1" />
                        </layoutData>
                    </Input>
                    <core:Icon id="checkWarehouse" color="green" src="sap-icon://sys-enter-2" size="26px" visible="false"/>
                </HBox>
                <Button id="submitButton" text="SUBMIT" visible="false"/>
            </VBox>
        </content>
        <footer>
            <Toolbar design="Solid">
                <ToolbarSpacer />
                <Text text="F1=Logout" />
                <ToolbarSpacer />
                <Text text="F2=Reset" />
                <ToolbarSpacer />
                <Text text="F3=Back" />
                <ToolbarSpacer />
                <Text text="F7=Help" />
                <ToolbarSpacer />
            </Toolbar>
        </footer>
    </Page>
</mvc:View>
