<mvc:View controllerName="rfgundemo.controller.MainScreen"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m" displayBlock="true">
    <Page title="SMR Demo Apps" id="mainScreenPage">
        <VBox class="sapUiSmallMargin" justifyContent="Center" alignItems="Center" fitContainer="true">
            <Label text="Purchase Order (Scan)" labelFor="purchaseOrderNumber" />
            <Input placeholder="Purchase Order" id="purchaseOrderNumber" required="true" submit=".onPurchaseOrderSubmit" maxLength="10">
            </Input>
        </VBox>
        <footer>
            <Toolbar design="Solid" visible="{device>/system/phone}">
                <ToolbarSpacer />
                <Button text="Back (F3)" press=".onNavBack"/>
                <ToolbarSpacer />
                <Button text="Enter (F4)" press=".onPurchaseOrderSubmit"/>
                <ToolbarSpacer />
            </Toolbar>
        </footer>
    </Page>
</mvc:View>
