<!--
    Data Detail View
    Purpose: Displays detailed line item data for a selected Purchase Order.
    Includes table layout for desktop and carousel layout for phones, plus a toolbar with action
buttons.
    Includes table layout for desktop and carousel layout for phones, plus a toolbar with action
buttons.
-->
<mvc:View
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    controllerName="rfgundemo.controller.DataDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    displayBlock="true"
>
    <!--
        Main page container with title and navigation button.
        Provides padding and responsive behavior.
    -->
    <Page
        id="dataDetailPage"
        title="SMR Demo Apps"
        showNavButton="true"
        navButtonPress=".onNavBack"
        class="sapUiResponsiveContentPadding"
    >
        <!--
            Subheader toolbar with page title and "Save and Post" action button.
        -->
        <subHeader>
            <Toolbar>
                <Title
                    id="orderDetailsTitle"
                    text="Order Details"
                    class="sapUiTinyMarginBegin"
                />
                <ToolbarSpacer />
                <Button
                    id="saveAndPostButton"
                    icon="sap-icon://save"
                    press=".onSaveAndPostButtonPress"
                    text="Save and Post"
                    type="Emphasized"
                    class="sapUiTinyMarginEnd"
                />
            </Toolbar>
        </subHeader>

        <!--
            Table to display Purchase Order line items for desktop/tablet users.
            Uses multi-selection and OData list binding.
        -->
        <Table
            id="orderTable"
            mode="MultiSelect"
            items="{path: '/ZR_RF_PO_ITEM_MAIN'}"
            inset="false"
            class="sapUiResponsiveContentPadding"
            visible="{= !${device>/system/phone} }"
        >
            <!--
                Table Columns (Desktop/Tablet view).
                Each column displays a specific field from the PO line item.
            -->
            <columns>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    width="3.5rem"
                    hAlign="Center"
                >
                    <Text text="No" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    visible="false"
                    hAlign="Center"
                >
                    <Text text="Material" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    visible="false"
                    hAlign="Center"
                >
                    <Text text="Material Desc" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    width="17rem"
                    hAlign="Center"
                >
                    <Text text="Material" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    width="7rem"
                    hAlign="Center"
                >
                    <Text text="Quantity Suggest" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    width="7rem"
                    hAlign="Center"
                >
                    <Text text="Quantity Receive" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    width="3.5rem"
                    hAlign="Center"
                >
                    <Text text="Unit" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    width="7rem"
                    hAlign="Center"
                >
                    <Text text="Plant" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    width="7rem"
                    hAlign="Center"
                >
                    <Text text="Storage Location" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    hAlign="Center"
                >
                    <Text text="Attachment" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    hAlign="Center"
                >
                    <Text text="Upload/Download" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    width="5rem"
                    hAlign="Center"
                >
                    <Text text="Confirm" />
                </Column>
            </columns>

            <!--
                Table Row Items
                Each row corresponds to one Purchase Order item.
            -->
            <items>
                <ColumnListItem>
                    <cells>
                        <Input
                            value="{PurchaseOrderItemNo}"
                            editable="false"
                            width="100%"
                        />
                        <Input
                            value="{Material}"
                            editable="false"
                            visible="false"
                        />
                        <Input
                            value="{MaterialDescription}"
                            editable="false"
                            visible="false"
                        />
                        <Input
                            value="{Material} {MaterialDescription}"
                            editable="false"
                            width="100%"
                        />
                        <Input
                            value="{QuantitySuggest}"
                            editable="false"
                            width="100%"
                            liveChange=".onLiveChangeCheckNumber"
                        />
                        <Input
                            value=""
                            width="100%"
                            liveChange=".onLiveChangeCheckNumber"
                        />
                        <Input
                            value="{PurchaseOrderQuantityUnit}"
                            editable="false"
                            width="100%"
                        />
                        <Input
                            value="{path: 'Plant', mode: 'sap.ui.model.BindingMode.OneWay'}"
                            width="100%"
                            showValueHelp="true"
                            valueHelpRequest="onPlantVHRequest"
                        />
                        <Input
                            value="{path: 'StorageLocation', mode: 'sap.ui.model.BindingMode.OneWay'}"
                            width="100%"
                            showValueHelp="true"
                            valueHelpRequest="onStrLocVHRequest"
                        />
                        <Link
                            text="{filename}"
                            emphasized="true"
                        />
                        <HBox
                            width="100%"
                            justifyContent="Center"
                            wrap="Wrap"
                        >
                            <Button
                                icon="sap-icon://upload"
                                class="sapUiTinyMarginEnd"
                                press="onUpload"
                            />
                            <Button
                                icon="sap-icon://download"
                                class="sapUiTinyMarginEnd"
                                press="onDownload"
                            />
                        </HBox>

                        <ToggleButton
                            text="OK"
                            press=".onOkButtonPress"
                            width="100%"
                            type="Emphasized"
                        />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>

        <!--
            Carousel for displaying Purchase Order line items on phones.
            Uses a card-style layout for small screens.
        -->
        <!-- Replace the entire Carousel with this optimized VBox -->
        <VBox
            class="sapUiTinyMargin"
            id="orderCarousel"
            visible="{device>/system/phone}"
        >
            <!-- Content Area - Single item only -->
            <VBox
                class="sapUiSmallMargin"
                visible="{= !${view>/isLoading}}"
            >
                <!-- Line No -->
                <VBox class="sapUiTinyMargin">
                    <Label text="Line No:" />
                    <Input
                        value="{view>/POItem/PurchaseOrderItemNo}"
                        editable="false"
                    />
                </VBox>

                <!-- Material - Combined for mobile optimization -->
                <VBox class="sapUiTinyMargin">
                    <Label text="Material" />
                    <Input
                        value="{parts: ['view>/POItem/Material', 'view>/POItem/MaterialDescription']}"
                        editable="false"
                    />
                </VBox>

                <!-- Quantity Fields - Critical for focus handling -->
                <HBox class="sapUiTinyMargin">
                    <VBox class="sapUiTinyMarginEnd">
                        <Label text="Qty Suggest:" />
                        <Input
                            value="{view>/POItem/QuantitySuggest}"
                            editable="false"
                            width="7rem"
                        />
                    </VBox>
                    <VBox>
                        <Label text="Qty Receive:" />
                        <Input
                            id="quantityReceiveInput"
                            value="{view>/POItem/QuantityReceive}"
                            liveChange=".onQuantityReceiveChange"
                            width="7rem"
                            type="Number"
                        />
                    </VBox>
                </HBox>

                <!-- Unit -->
                <VBox class="sapUiTinyMargin">
                    <Label text="Unit:" />
                    <Input
                        value="{view>/POItem/PurchaseOrderQuantityUnit}"
                        editable="false"
                        width="7rem"
                    />
                </VBox>

                <!-- Plant -->
                <VBox class="sapUiTinyMargin">
                    <Label text="Plant:" />
                    <Input
                        value="{view>/POItem/Plant}"
                        showValueHelp="true"
                        valueHelpRequest="onPlantVHRequest"
                    />
                </VBox>

                <!-- Storage Location -->
                <VBox class="sapUiTinyMargin">
                    <Label text="Storage Location:" />
                    <Input
                        value="{view>/POItem/StorageLocation}"
                        width="100%"
                        showValueHelp="true"
                        valueHelpRequest="onStrLocVHRequest"
                    />
                </VBox>

                <!-- Attachment Buttons - Smaller for mobile -->
                <HBox class="sapUiTinyMargin">
                    <Button
                        icon="sap-icon://upload"
                        class="sapUiTinyMarginEnd"
                        press="onUpload"
                        width="3rem"
                    />
                    <Button
                        icon="sap-icon://download"
                        class="sapUiTinyMarginEnd"
                        press="onDownload"
                        width="3rem"
                    />
                </HBox>
                <VBox class="sapUiTinyMargin">
                    <Button
                        text="{view>/POItem/filename}"
                        type="Transparent"
                        visible="{= !!${view>/POItem/filename}}"
                    />
                </VBox>

                <!-- Action Buttons -->
                <HBox class="sapUiTinyMargin">
                    <ToggleButton
                        text="Confirm"
                        press=".onOkButtonPress"
                        width="100%"
                        type="Emphasized"
                    />
                </HBox>
            </VBox>
            <!-- Navigation Header - Compact for mobile -->
            <HBox
                class="sapUiTinyMargin"
                justifyContent="SpaceBetween"
                alignItems="Center"
            >
                <!-- Previous Button -->
                <Button
                    icon="sap-icon://navigation-left-arrow"
                    tooltip="Previous Item"
                    press=".onPreviousItem"
                    enabled="{view>/canGoPrevious}"
                    type="Default"
                    width="3rem"
                />

                <!-- Status Text -->
                <VBox alignItems="Center">
                    <Text
                        text="Item {view>/currentIndex} of {view>/totalItems}"
                        class="sapUiTinyText"
                    />
                </VBox>

                <!-- Next Button -->
                <Button
                    icon="sap-icon://navigation-right-arrow"
                    tooltip="Next Item"
                    press=".onNextItem"
                    enabled="{view>/canGoNext}"
                    type="Default"
                    width="3rem"
                />
            </HBox>
        </VBox>

        <!--
            Footer bar with keyboard shortcut hints for phone users.
        -->
        <footer>
            <OverflowToolbar>
                <HBox
                    visible="{= !${device>/system/phone} }"
                    class="sapUiContentPadding"
                >
                    <Button
                        id="messagePopoverBtn"
                        visible="{=!!${message>/}.length}"
                        icon="{
                        parts: ['message>/'],
                        formatter: '.getButtonIcon'
                    }"
                        type="{
                        parts: ['message>/'],
                        formatter: '.getButtonType'
                    }"
                        text="{
                        parts: ['message>/'],
                        formatter: '.getMessageCount'
                    }"
                        press="onShowMessagePopover"
                        ariaHasPopup="Dialog"
                    />
                </HBox>
                <!-- Phone keyboard shortcuts - only visible on phone devices -->
                <HBox
                    visible="{device>/system/phone}"
                    class="sapUiContentPadding"
                    width="100%"
                    justifyContent="Center"
                >
                    <Text
                        text="Back (F3)"
                        class="sapUiSmallMargin"
                        textAlign="Center"
                    />
                    <Text
                        text="Next (F5)"
                        class="sapUiSmallMargin"
                        textAlign="Center"
                    />
                    <Text
                        text="Previous (F6)"
                        class="sapUiSmallMargin"
                        textAlign="Center"
                    />
                    <Text
                        text="(un)Confirm (F7)"
                        class="sapUiSmallMargin"
                        textAlign="Center"
                    />
                    <Text
                        text="Save (F8)"
                        class="sapUiSmallMargin"
                        textAlign="Center"
                    />
                </HBox>
                <ToolbarSpacer />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
