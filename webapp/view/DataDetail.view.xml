<!--
    Data Detail View
    Purpose: Displays detailed line item data for a selected Purchase Order.
    Includes table layout for desktop and carousel layout for phones, plus a toolbar with action
buttons.
    Includes table layout for desktop and carousel layout for phones, plus a toolbar with action
buttons.
-->
<mvc:View
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    controllerName="rfgundemo.controller.DataDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    displayBlock="true"
>
    <!--
        Main page container with title and navigation button.
        Provides padding and responsive behavior.
    -->
    <Page
        id="dataDetailPage"
        title="SMR Demo Apps"
        showNavButton="true"
        navButtonPress=".onNavBack"
        class="sapUiResponsiveContentPadding"
    >
        <!--
            Subheader toolbar with page title and "Save and Post" action button.
        -->
        <subHeader>
            <Toolbar>
                <Title
                    id="orderDetailsTitle"
                    class="sapUiTinyMarginBegin"
                />
                <ToolbarSpacer />
                <Button
                    id="saveAndPostButton"
                    icon="sap-icon://save"
                    press=".onSaveAndPostButtonPress"
                    text="Save and Post"
                    type="Emphasized"
                    class="sapUiTinyMarginEnd"
                />
            </Toolbar>
        </subHeader>

        <!--
            Table to display Purchase Order line items for desktop/tablet users.
            Uses multi-selection and OData list binding.
        -->
        <Table
            id="orderTable"
            mode="MultiSelect"
            items="{ path: 'POModel>/tableData'}"
            inset="false"
            class="sapUiResponsiveContentPadding"
        >
            <headerToolbar>
                <Toolbar>
                    <Title
                        id="orderListTitle"
                        level="H2"
                        text="Total items: {$count}"
                    />
                </Toolbar>
            </headerToolbar>
            <!--
                Table Columns (Desktop/Tablet view).
                Each column displays a specific field from the PO line item.
            -->
            <columns>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    width="3.5rem"
                    hAlign="Center"
                >
                    <Text text="No" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    visible="false"
                    hAlign="Center"
                >
                    <Text text="Material" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    visible="false"
                    hAlign="Center"
                >
                    <Text text="Material Desc" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    width="17rem"
                    hAlign="Center"
                >
                    <Text text="Material" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    width="7rem"
                    hAlign="Center"
                >
                    <Text text="Quantity Suggest" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    width="7rem"
                    hAlign="Center"
                >
                    <Text text="Quantity Receive" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    width="3.5rem"
                    hAlign="Center"
                >
                    <Text text="Unit" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    width="7rem"
                    hAlign="Center"
                >
                    <Text text="Plant" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    width="7rem"
                    hAlign="Center"
                >
                    <Text text="Storage Location" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    hAlign="Center"
                >
                    <Text text="Attachment" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    hAlign="Center"
                >
                    <Text text="Upload/Download" />
                </Column>
                <Column
                    demandPopin="true"
                    minScreenWidth="Tablet"
                    width="5rem"
                    hAlign="Center"
                >
                    <Text text="Confirm" />
                </Column>
            </columns>

            <!--
                Table Row Items
                Each row corresponds to one Purchase Order item.
            -->
            <items>
                <ColumnListItem>
                    <cells>
                        <Input
                            value="{POModel>PurchaseOrderItemNo}"
                            editable="false"
                            width="100%"
                        />
                        <Input
                            value="{POModel>Material}"
                            editable="false"
                            visible="false"
                        />
                        <Input
                            value="{POModel>MaterialDescription}"
                            editable="false"
                            visible="false"
                        />
                        <Input
                            value="{POModel>Material} {POModel>MaterialDescription}"
                            editable="false"
                            width="100%"
                        />
                        <Input
                            value="{POModel>QuantitySuggest}"
                            editable="false"
                            width="100%"
                            liveChange=".onLiveChangeCheckNumber"
                        />
                        <Input
                            value=""
                            width="100%"
                            liveChange=".onLiveChangeCheckNumber"
                        />
                        <Input
                            value="{POModel>PurchaseOrderQuantityUnit}"
                            editable="false"
                            width="100%"
                        />
                        <Input
                            value="{path: 'POModel>Plant', mode: 'sap.ui.model.BindingMode.OneWay'}"
                            width="100%"
                            showValueHelp="true"
                            valueHelpRequest="onPlantVHRequest"
                        />
                        <Input
                            value="{path: 'POModel>StorageLocation', mode: 'sap.ui.model.BindingMode.OneWay'}"
                            width="100%"
                            showValueHelp="true"
                            valueHelpRequest="onStrLocVHRequest"
                        />
                        <Link
                            text="{POModel>filename}"
                            emphasized="true"
                        />
                        <HBox
                            width="100%"
                            justifyContent="Center"
                            wrap="Wrap"
                        >
                            <Button
                                icon="sap-icon://upload"
                                class="sapUiTinyMarginEnd"
                                press="onUpload"
                            />
                            <Button
                                icon="sap-icon://download"
                                class="sapUiTinyMarginEnd"
                                press="onDownload"
                            />
                        </HBox>

                        <ToggleButton
                            text="OK"
                            press=".onOkButtonPress"
                            width="100%"
                            type="Emphasized"
                        />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>

        <!-- Pagination Control -->
        <OverflowToolbar>
            <ToolbarSpacer />
            <Button
                id="BtnFirstPressId"
                icon="sap-icon://close-command-field"
                press="onFirstPress"
                tooltip="First"
                enabled="{NavModel>/firstPageBtnEnable}"
            />
            <Button
                id="BtnPreviousPressId"
                icon="sap-icon://navigation-left-arrow"
                press="onPreviousPress"
                tooltip="Previous"
                enabled="{NavModel>/firstPageBtnEnable}"
            />
            <Text
                id="PageTextId"
                text="page {POModel>/page} of {POModel>/totalPages}"
            />
            <Button
                id="BtnNextPressId"
                icon="sap-icon://navigation-right-arrow"
                press="onNextPress"
                tooltip="Next"
                enabled="{NavModel>/nextPageBtnEnable}"
            />
            <Button
                id="BtnLastPressId"
                icon="sap-icon://open-command-field"
                press="onLastPress"
                tooltip="Last"
                enabled="{NavModel>/nextPageBtnEnable}"
            />
        </OverflowToolbar>

        <!--
            Footer bar with keyboard shortcut hints for phone users.
        -->
        <footer>
            <OverflowToolbar>
                <VBox />
                <HBox
                    visible="{= !${device>/system/phone} }"
                    class="sapUiContentPadding"
                >
                    <Button
                        id="messagePopoverBtn"
                        visible="{=!!${message>/}.length}"
                        icon="{
                        parts: ['message>/'],
                        formatter: '.getButtonIcon'
                    }"
                        type="{
                        parts: ['message>/'],
                        formatter: '.getButtonType'
                    }"
                        text="{
                        parts: ['message>/'],
                        formatter: '.getMessageCount'
                    }"
                        press="onShowMessagePopover"
                        ariaHasPopup="Dialog"
                    />
                </HBox>
                <!-- Phone keyboard shortcuts - only visible on phone devices -->
                <HBox
                    visible="{device>/system/phone}"
                    class="sapUiContentPadding"
                    width="100%"
                    justifyContent="Center"
                >
                    <Text
                        text="Back (F3)"
                        class="sapUiSmallMargin"
                        textAlign="Center"
                    />
                    <Text
                        text="Next (F5)"
                        class="sapUiSmallMargin"
                        textAlign="Center"
                    />
                    <Text
                        text="Previous (F6)"
                        class="sapUiSmallMargin"
                        textAlign="Center"
                    />
                    <Text
                        text="(un)Confirm (F7)"
                        class="sapUiSmallMargin"
                        textAlign="Center"
                    />
                    <Text
                        text="Save (F8)"
                        class="sapUiSmallMargin"
                        textAlign="Center"
                    />
                </HBox>
                <ToolbarSpacer />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
